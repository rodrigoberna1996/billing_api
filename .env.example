BILLING_API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://billing_api:billing_api@localhost:5432/billing_api
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_DECODE_RESPONSES=true

# Borradores de formulario (Redis): TTL en segundos (default 30 dias) y tamano maximo del JSON en bytes
INVOICE_DRAFT_TTL_SECONDS=2592000
INVOICE_DRAFT_MAX_BYTES=524288

# Internal API Key (comunicacion servidor-a-servidor entre microservicios)
INTERNAL_API_KEY=tu-clave-interna-aqui

# CORS: origenes permitidos separados por coma. Si esta vacio y BILLING_API_ENV=development,
# se permiten localhost en puertos tipicos de Vite/React (3000, 5173, 4173).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# FacturaloPlus PAC — timbrado de CFDI
# Sandbox: https://dev.facturaloplus.com  |  Produccion: https://app.facturaloplus.com
FACTURALO_BASE_URL=https://dev.facturaloplus.com
# API Key de 32 caracteres — obtener en tu cuenta de FacturaloPlus
FACTURALO_API_KEY=tu-api-key-de-32-chars-aqui
# Archivo .key del CSD convertido a PEM: openssl pkcs8 -inform DER -in archivo.key -out key.pem
FACTURALO_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# Archivo .cer del CSD convertido a PEM: openssl x509 -inform DER -in archivo.cer -out cer.pem
FACTURALO_CER_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# Para cancelacion — .key en base64: cat archivo.key | base64 -w0
FACTURALO_CSD_KEY_B64=base64-del-archivo-key
# Para cancelacion — .cer en base64: cat archivo.cer | base64 -w0
FACTURALO_CSD_CER_B64=base64-del-archivo-cer
# Contrasena de la llave privada CSD
FACTURALO_CSD_PASSWORD=tu-contrasena-csd
# Numero de serie del CSD (opcional, para NoCertificado en el XML)
FACTURALO_CSD_SERIAL=

# Datos del emisor (empresa timbradora) — RESPALDO opcional.
# El emisor "real" se gestiona desde el modulo "Mi cuenta" en adrh_logistics
# (tabla empresa_fiscal) y se envia en el campo `emisor` de cada request de
# timbrado. Estas variables solo se usan si el request no incluye `emisor`
# o le falta algun campo (rfc/razon_social/cp/regimen_fiscal).
FACTURALO_EMISOR_RFC=XAXX000000000
FACTURALO_EMISOR_NOMBRE=MI EMPRESA SA DE CV
FACTURALO_EMISOR_CP=00000
FACTURALO_EMISOR_REGIMEN=601
# Nombre de la plantilla PDF (ver catalogo en facturaloplus.com/developers)
FACTURALO_PDF_PLANTILLA=transporteterrestre31
# Timeout HTTP para llamadas a FacturaloPlus (segundos). Aumentar para payloads con 500+ mercancias.
FACTURALO_TIMEOUT=480

# adrh_logistics — callback event-driven post-timbrado
# URL base del API de logistica (para notificar el cfdi_uuid al viaje correspondiente)
LOGISTICS_API_URL=http://localhost:8000
# Debe coincidir con INTERNAL_API_KEY configurada en adrh_logistics/.env
LOGISTICS_API_KEY=lj6ZpnBZeFkj0ruT8AYgc7EBI/i3vi6L4s5HdS6hl38=
