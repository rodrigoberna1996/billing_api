BILLING_API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://billing_api:billing_api@localhost:5432/billing_api
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_DECODE_RESPONSES=true

# Borradores de formulario (Redis): TTL en segundos (default 30 dias) y tamano maximo del JSON en bytes
INVOICE_DRAFT_TTL_SECONDS=2592000
INVOICE_DRAFT_MAX_BYTES=524288

# Facturify API Configuration
FACTURIFY_BASE_URL=https://api-sandbox.facturify.com
FACTURIFY_API_KEY=tu-api-key-aqui
FACTURIFY_API_SECRET=tu-api-secret-aqui
FACTURIFY_ACCOUNT_UUID=uuid-del-emisor-registrado
FACTURIFY_TIMEOUT=30
FACTURIFY_MAX_RETRIES=3
FACTURIFY_RETRY_BACKOFF=2.0
FACTURIFY_TOKEN_REFRESH_BUFFER=60

# Internal API Key (comunicacion servidor-a-servidor)
INTERNAL_API_KEY=tu-clave-interna-aqui

# CORS: origenes permitidos separados por coma. Si esta vacio y BILLING_API_ENV=development,
# se permiten localhost en puertos tipicos de Vite/React (3000, 5173, 4173).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
